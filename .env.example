# =============================================================================
# Bot_noct Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
WEBAPP_URL=https://your-webapp-url.com
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (default - file-based)
DB_PATH=./data/bot.sqlite

# PostgreSQL (optional - for production)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bot_noct
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_SSL=false

# -----------------------------------------------------------------------------
# Redis Configuration (Cache & Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_SESSION=3600        # 1 hour - session data
CACHE_TTL_CATALOG=300         # 5 minutes - product catalog
CACHE_TTL_STATS=60             # 1 minute - statistics
CACHE_TTL_USER=1800            # 30 minutes - user data
CACHE_TTL_LEAD=300             # 5 minutes - lead data

# -----------------------------------------------------------------------------
# Queue Configuration
# -----------------------------------------------------------------------------
QUEUE_ENABLED=true
QUEUE_CONCURRENCY_MESSAGES=5
QUEUE_CONCURRENCY_WEBHOOKS=10
QUEUE_CONCURRENCY_BATCH=2

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info                 # debug, info, warn, error, fatal
LOG_FORMAT=json                # json, pretty, simple
LOG_REDACT_PATTERNS=password,token,secret,authorization

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_SECRET=your_api_secret_here
API_RATE_LIMIT_WINDOW=60000    # 1 minute window
API_RATE_LIMIT_MAX=100         # max requests per window
API_COMPRESSION=true

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Webhook for external integrations
WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_URL=https://your-domain.com/webhook

# CRM Integration (optional)
# CRM_WEBHOOK_URL=https://your-crm.com/webhook
# CRM_API_KEY=your_crm_api_key

# -----------------------------------------------------------------------------
# Render.com Configuration
# -----------------------------------------------------------------------------
RENDER_EXTERNAL_URL=https://your-app.onrender.com
RENDER_API_TOKEN=your_render_api_token
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploys/deploy_hook_id

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Enable/disable features
ALLOW_DIAGNOSTICS=true
ENABLE_DEBUG_ENDPOINTS=false

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_MESSAGES=30    # per minute
RATE_LIMIT_MAX_CallbackQuery=60 # per minute

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------
# Worker pool size (0 = auto based on CPU cores)
WORKER_POOL_SIZE=0

# Memory limits (MB)
MEMORY_LIMIT_WARN=512
MEMORY_LIMIT_CRITICAL=768

# Request timeout (ms)
REQUEST_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_NEW_CATALOG=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_WEBAPP_FORMS=true
FEATURE_BULK_OPERATIONS=true
