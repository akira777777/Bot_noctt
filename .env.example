NODE_ENV=development
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789
DB_PATH=./data/bot.sqlite
BACKUP_RETENTION=50
BACKUP_DIR=./backups
PORT=3081

# API security
API_SECRET=your_random_api_secret_key
CORS_ORIGIN=https://your-dashboard.vercel.app

# Webhook mode (optional — uses polling if not set)
# WEBHOOK_DOMAIN=https://your-service.onrender.com

# Next.js dashboard env vars (set in Vercel)
# API_URL=https://your-service.onrender.com
# NEXT_PUBLIC_BOT_USERNAME=your_bot_username
# JWT_SECRET=your_random_jwt_secret
