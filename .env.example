# Bot_noct Environment Template

# Required
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789

# App
NODE_ENV=development
PORT=3000
DEV_PORT=3001
DB_PATH=./data/bot.sqlite
# Legacy alias supported for compatibility:
# DATABASE_PATH=./data/bot.sqlite

# Telegram delivery:
# - polling (recommended for local dev)
# - webhook (recommended for production)
TELEGRAM_DELIVERY_MODE=polling
WEBHOOK_DOMAIN=
TELEGRAM_STARTUP_TIMEOUT_MS=15000
ALLOW_BOT_LAUNCH_FAILURE=false

# Web
WEB_APP_URL=https://your-miniapp-domain.example/mini-app
CORS_ORIGIN=
# Legacy alias supported for compatibility:
# ALLOWED_ORIGINS=

# API
# Required in production for admin HTTP endpoints. If unset, admin API stays disabled.
API_SECRET=replace_with_strong_secret
API_COMPRESSION=true
JWT_SECRET=replace_with_long_random_secret

# Redis (optional; memory fallback is used when unavailable)
# Optional URL form is supported for cache-service standalone usage:
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Web dashboard
API_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BOT_USERNAME=your_bot_username

# Logging / performance
LOG_LEVEL=info
LOG_FORMAT=json
MEMORY_LIMIT_WARN=512
MEMORY_LIMIT_CRITICAL=768
CACHE_TTL_SESSION=3600
CACHE_TTL_CATALOG=300
CACHE_TTL_PRODUCT=600
CACHE_TTL_STATS=60
CACHE_TTL_USER=1800
CACHE_TTL_LEAD=300
CACHE_TTL_CONVERSATION=900
