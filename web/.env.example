# web/.env.example — Next.js dashboard environment template
# Copy to web/.env.local for local development.
# Variables without NEXT_PUBLIC_ are server-side only (route handlers, SSR).
# Variables with NEXT_PUBLIC_ are bundled into the browser.

# URL of the bot's Express API (used by Next.js proxy route handlers server-side)
API_URL=http://localhost:3000

# Publicly accessible base URL of this Next.js app (used for absolute links)
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Telegram bot username shown in UI (no @ prefix)
NEXT_PUBLIC_BOT_USERNAME=your_bot_username
