{
  "name": "bot_noct",
  "version": "1.0.0",
  "description": "Telegram inquiry and support bot with Express API, SQLite, and Next.js admin",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "start:prod": "NODE_ENV=production node index.js",
    "dev": "node --watch index.js",
    "dev:watch": "NODE_ENV=development node --watch index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines 70 --functions 35 --branches 60 --statements 70 node --test",
    "lint": "node --check index.js && node --check src/bot.js && node --check src/web/server.js",
    "lint:fix": "node --check index.js && node --check src/bot.js && node --check src/web/server.js",
    "backup": "node scripts/backup-sqlite.js",
    "restore-check": "node scripts/restore-check.js",
    "build:web": "npm --prefix web run build",
    "dev:web": "npm --prefix web run dev",
    "preview:web": "npm --prefix web run start",
    "smoke:api": "node scripts/smoke-api.js",
    "smoke:status": "npm run smoke:api",
    "pm2:start": "npm run validate && pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop bot-noct",
    "pm2:restart": "pm2 restart bot-noct",
    "pm2:logs": "pm2 logs bot-noct --lines 100",
    "pm2:monit": "pm2 monit",
    "validate": "node scripts/startup-check.js",
    "health": "node scripts/health-check.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "ai": "^6.0.136",
    "better-sqlite3": "^12.8.0",
    "bull": "^4.16.5",
    "compression": "^1.7.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.16.0",
    "pino": "^9.12.0",
    "pino-pretty": "^13.1.2",
    "telegraf": "^4.16.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "c8": "^10.1.3"
  }
}
