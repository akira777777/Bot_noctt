{
  "name": "bot_noct",
  "version": "1.0.0",
  "description": "Telegram support bot for channel using Telegraf",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "backup": "node scripts/backup-sqlite.js",
    "restore-check": "node scripts/restore-check.js",
    "dev:web": "vite --config webapp/vite.config.js",
    "build:web": "vite build --config webapp/vite.config.js",
    "preview:web": "vite preview --config webapp/vite.config.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0"
  }
}
