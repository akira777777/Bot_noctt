# =============================================================================
# Docker Ignore Patterns
# Exclude unnecessary files from Docker build context
# =============================================================================

# Git
.git
.gitignore
.gitmodules
.gitattributes

# Documentation
*.md
!README.md
docs/
LICENSE

# Docker files (not needed inside image)
Dockerfile*
docker-compose*.yml
.dockerignore

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Test coverage and reports
coverage/
*.lcov
htmlcov/
.nyc_output/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# Environment files (secrets)
.env
.env.*
!.env.example
!.env.local

# Development files
webapp/node_modules/
webapp/dist/
*.test.js
*.spec.js
test/
scripts/
scripts/*.js

# Logs
logs/
*.log
npm-debug.log*

# Build artifacts
*.tgz
dist/
build/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Kubernetes (if not needed)
.kube/
*.kubeconfig

# Render MCP Server (has its own Dockerfile)
render-mcp-server/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Development specific
.vscode/
.idea/
*.sublime-*

# OS files
Thumbs.db
.DS_Store
