# =============================================================================
# Bot_noct - Development Dockerfile
# With hot reload support and debugger
# =============================================================================

FROM node:20-alpine

# Install runtime dependencies for native modules (better-sqlite3)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    sqlite \
    bash \
    && rm -rf /var/cache/apk/*

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm ci

# Copy application source
COPY . .

# Create data directory
RUN mkdir -p data && chmod 777 data

# Expose ports
EXPOSE 3000 9229

# Development command with hot reload
CMD ["node", "--watch", "--inspect=0.0.0.0:9229", "index.js"]
