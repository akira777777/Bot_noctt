# =============================================================================
# Bot_noct Production Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
# ПОЛУЧИТЬ ТОКЕН: https://t.me/BotFather -> /newbot или /token
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
PORT=3052
NODE_ENV=production
WEBAPP_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (для небольших проектов)
DB_PATH=./data/bot.sqlite

# PostgreSQL (рекомендуется для продакшена)
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_NAME=bot_noct
# DB_USER=bot_user
# DB_PASSWORD=SECURE_PASSWORD_HERE
# DB_SSL=true

# -----------------------------------------------------------------------------
# Redis Configuration (Cache & Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=SECURE_REDIS_PASSWORD
REDIS_DB=0

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_SESSION=3600
CACHE_TTL_CATALOG=300
CACHE_TTL_STATS=60
CACHE_TTL_USER=1800
CACHE_TTL_LEAD=300

# -----------------------------------------------------------------------------
# Queue Configuration
# -----------------------------------------------------------------------------
QUEUE_ENABLED=true
QUEUE_CONCURRENCY_MESSAGES=10
QUEUE_CONCURRENCY_WEBHOOKS=20
QUEUE_CONCURRENCY_BATCH=3

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REDACT_PATTERNS=password,token,secret,authorization,BOT_TOKEN,REDIS_PASSWORD

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_SECRET=CHANGE_THIS_TO_VERY_SECURE_SECRET
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=100
API_COMPRESSION=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
ALLOW_DIAGNOSTICS=false
ENABLE_DEBUG_ENDPOINTS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_MESSAGES=30
RATE_LIMIT_MAX_CallbackQuery=60

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------
WORKER_POOL_SIZE=0
MEMORY_LIMIT_WARN=512
MEMORY_LIMIT_CRITICAL=768
REQUEST_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_NEW_CATALOG=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_WEBAPP_FORMS=true
FEATURE_BULK_OPERATIONS=true
